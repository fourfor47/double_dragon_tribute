; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Double Dragon Tribute"
config/description="A tribute to the classic beat 'em up game. Built with Godot 4.x, completely free and open source."
run/main_scene="res://scenes/main_menu.tscn"
config/features=PackedStringArray("4.2", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://scripts/game_manager.gd"
InputManager="*res://scripts/input_manager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/resizable=true
window/size/initial_position=1
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[gui]

theme/custom="res://theme/theme.tres"

